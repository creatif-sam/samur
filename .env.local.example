# ============================================
# PUSH NOTIFICATION SETUP (VAPID KEYS)
# ============================================
# These keys enable actual push notifications that appear on your screen,
# locked screen, and when the app is closed.
# 
# COPY THIS FILE TO .env.local AND ADD THESE VALUES:

# Public VAPID key (safe to expose to client)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJfF9EznPDMXDaxjrubMuEJ25PaT04JL0FmrQvIGk4HR6IsHQyuSW-uYJMH8_kkJi4mWzhbrfiWEzMZ6lpPthXg

# Private VAPID key (keep secret, server-side only)
VAPID_PRIVATE_KEY=N8DGn6nQ2yQhRn-lmObwCy1iwaWka4422pVvNkYvQ2A

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Add your Supabase project credentials here
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# NOTE: 
# ============================================
# - The VAPID keys above were generated for you
# - To generate new keys, run: 
#   node -e "const webpush = require('web-push'); const keys = webpush.generateVAPIDKeys(); console.log('Public:', keys.publicKey, '\nPrivate:', keys.privateKey);"
# - Never commit .env.local to git (it's in .gitignore)
# - Keep VAPID_PRIVATE_KEY secret at all times
